{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "cssPriority": "application",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "notification-window-width": 360,
  "control-center-width": 360,
  "control-center-height": 0,
  "fit-to-screen": false,
  "notification-icon-size": 40,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 5,
  "timeout-low": 3,
  "timeout-critical": 0,
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "inhibitors",
    "title",
    "buttons-grid",
    "dnd",
    "volume",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Central de notificações",
      "clear-all-button": true,
      "button-text": "󰎟 Limpar"
    },
    "dnd": {
      "text": "Não perturbe"
    },
    "inhibitors": {
      "text": "Inibidores",
      "button-text": "󰖭 Desativar",
      "active-label": "󰖩 {inhibitor}"
    },
    "volume": {
      "label": "󰕾"
    },
    "mpris": {
      "image-size": 56,
      "image-radius": 6
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰤨",
          "command": "nmcli radio wifi toggle"
        },
        {
          "label": "󰂯",
          "command": "flatpak run io.github.kaii_lb.Overskride"
        },
        {
          "label": "󰌾",
          "command": "hyprlock"
        },
        {
          "label": "󰐥",
          "command": "systemctl poweroff"
        },
        {
          "label": "󰜉",
          "command": "systemctl reboot"
        }
      ]
    }
  }
}