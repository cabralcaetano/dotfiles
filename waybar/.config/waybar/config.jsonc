{
  // === BAR =====================================
  "layer": "top",
  "position": "top",
  "passthrough": false,
  "reload_on_style_change": true,

  // === MARGENS =================================
  "spacing": 10,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "margin-bottom": 1,

  // === Mأ“DULOS =================================
  "modules-left": ["custom/icon", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["network", "bluetooth", "pulseaudio", "custom/power-profile", "battery", "tray"],

  // === أچCONE CUSTOM ============================
  "custom/icon": {
    "format": ""
  },

  // === WORKSPACES ==============================
  "hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "1": "i",
      "2": "ii",
      "3": "iii",
      "4": "iv",
      "5": "v",
      "6": "vi",
      "7": "vii",
      "8": "viii",
      "9": "ix",
      "10": "x"
    }
  },

  // === JANELA ATIVA ============================
  "hyprland/window": {
    "separate-outputs": true,
    "max-length": 20,
    "format": "{class}"
  },

  // === RELأ“GIO =================================
  "clock": {
    "format": "{:%a %d %H:%M:%S}",
    "interval": 1,
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "format": {
        "today": "<b>{}</b>"
      }
    },
    "on-click": "swaync-client -t",
    "actions": {
      "on-click-right": "shift_down",
      "on-click": "shift_up"
      // "on-double-click": "gnome-calendar"
    }
  },

  // === BATERIA =================================
  "battery": {
  "adapter": "ADP0",
  "bat": "BAT0",
  "format": "{icon} {capacity}%",
  "format-charging": "َ°‚„ {capacity}%",
  "format-not-charging": "َ°ڑ¥ {capacity}%",
  "format-full": "َ°پ¹ {capacity}%",
  "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  // === TRAY ====================================
  "tray": {
    "icon-size": 16,
    "spacing": 5,
    "show-passive-items": true
  },

  // === REDE ====================================
"network": {
  "format-wifi": "{icon}",
  "format-ethernet": "َ°ˆ€",
  "format-disconnected": "َ°¤­",
  "format-icons": ["َ°¤¯", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
  "on-click": "nm-applet",
  "tooltip-format-wifi": "{essid} {signalStrength}%"
  },

  // === BLUETOOTH ================================
"bluetooth": {
  "format": "َ°‚¯",
  "format-connected": "َ°‚±",
  "format-off": "َ°‚²",
  "on-click": "flatpak run io.github.kaii_lb.Overskride",
  "tooltip": true,
  "tooltip-format-connected": "{device_alias}\nBateria: {device_battery_percentage}%"
  },

  // === PULSEAUDIO ================================
"pulseaudio": {
  "format": "{icon}",
  "icon-size": 16,
  "format-muted": "َ°–پ",
  "format-icons": {
    "default": ["َ°•؟", "َ°–€", "َ°•¾"]
  },
  "tooltip": true,
  "tooltip-format": "{volume}%",
  "scroll-step": 5,
  "on-click": "pavucontrol"
  },

  // === POWER ====================================
  "custom/power": {
  "format": "ï€‘",
  "on-click": "wlogout",
  "tooltip": false
  },

  // === PERFIL DE ENERGIA ========================
  "custom/power-profile": {
    "exec": "/home/caetano/.local/bin/power-profile.sh waybar",
    "exec-if": "/home/caetano/.local/bin/power-profile.sh waybar-check",
    "interval": 3,
    "tooltip": true,
    "tooltip-format": "Perfil de energia ativo"
  }
}

  